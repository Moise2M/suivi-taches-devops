# Configuration du serveur
PORT=3000
NODE_ENV=development

# ── IA pour l'export Pro ────────────────────────────────────────────────────
# Choisir le provider : groq | gemini | anthropic
AI_PROVIDER=groq

# Groq (gratuit) → https://console.groq.com → API Keys
# AI_API_KEY=gsk_...
# AI_MODEL=llama-3.3-70b-versatile

# Gemini (gratuit) → https://aistudio.google.com/app/apikey
# AI_API_KEY=AIza...
# AI_MODEL=gemini-2.0-flash

# Anthropic (payant) → https://console.anthropic.com
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-6

AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_MAX_TOKENS=4000

# Ancienne clé Anthropic (conservée pour référence)
# ANTHROPIC_API_KEY=sk-ant-...

# CORS (si frontend séparé)
CORS_ORIGIN=http://localhost:3000

# Logs
LOG_LEVEL=info
